<ui:FluentWindow
  x:Class="RA.Compagnon.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  mc:Ignorable="d"
  Title="Compagnon RA"
  Width="1100"
  Height="700"
  MinWidth="360"
  MinHeight="320"
  ResizeMode="CanResize"
  Cursor="Arrow"
  Background="Transparent"
  WindowStartupLocation="CenterScreen"
  ExtendsContentIntoTitleBar="True"
  WindowBackdropType="Mica"
  SizeChanged="FenetrePrincipale_TailleChangee"
>
  <Grid Background="Transparent">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Height="36" Margin="{StaticResource MargeFenetreHaut}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="220" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="220" />
      </Grid.ColumnDefinitions>

      <ui:TitleBar Grid.ColumnSpan="3" Height="36" />

      <Grid Grid.ColumnSpan="3" IsHitTestVisible="False">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="220" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="220" />
        </Grid.ColumnDefinitions>

        <Image
          x:Name="ImageIconeTitre"
          Grid.Column="0"
          Width="22"
          Height="22"
          Margin="14,0,0,0"
          HorizontalAlignment="Left"
          VerticalAlignment="Center"
          Stretch="Uniform"
        />

        <Viewbox
          x:Name="ConteneurTitreFenetre"
          Grid.Column="0"
          Grid.ColumnSpan="2"
          HorizontalAlignment="Left"
          VerticalAlignment="Center"
          Stretch="Uniform"
          StretchDirection="Both"
          Height="22"
          Margin="44,0,8,0"
        >
          <TextBlock
            x:Name="TexteTitreFenetre"
            FontSize="16"
            FontWeight="SemiBold"
            LineHeight="20"
            LineStackingStrategy="BlockLineHeight"
            Text="{Binding TitreFenetre}"
            TextWrapping="NoWrap"
            TextAlignment="Left"
          />
        </Viewbox>
      </Grid>
    </Grid>

    <Grid Grid.Row="1" Margin="12,8,12,6">
      <Grid VerticalAlignment="Center">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel
          Grid.Column="0"
          Margin="8,0,0,0"
          Orientation="Horizontal"
          VerticalAlignment="Center"
        >
          <StackPanel
            x:Name="ZoneEtatCompteUtilisateur"
            MaxWidth="320"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Visibility="{Binding Compte.NoticeVisible, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
          >
            <Border
              x:Name="BadgeEtatCompteUtilisateur"
              Padding="0"
              HorizontalAlignment="Left"
              CornerRadius="0"
              Background="{Binding Compte.FondNotice}"
              BorderBrush="{Binding Compte.BordureNotice}"
              BorderThickness="0"
            >
              <TextBlock
                x:Name="TexteEtatCompteUtilisateur"
                FontSize="22"
                FontWeight="SemiBold"
                Opacity="0.92"
                Text="{Binding Compte.EtatNotice}"
                TextAlignment="Left"
              />
            </Border>

            <TextBlock
              x:Name="TexteSousEtatCompteUtilisateur"
              Margin="2,3,0,0"
              HorizontalAlignment="Left"
              FontSize="11"
              Opacity="0.45"
              TextAlignment="Left"
              Text="{Binding Compte.SousEtatNotice}"
              TextTrimming="CharacterEllipsis"
              Visibility="{Binding Compte.SousEtatVisible, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
            />
          </StackPanel>
        </StackPanel>

        <StackPanel
          Grid.Column="1"
          HorizontalAlignment="Right"
          Orientation="Horizontal"
          VerticalAlignment="Center"
        >
          <ui:Button
            x:Name="BoutonRechargerJeu"
            Margin="0,0,10,0"
            Height="28"
            Padding="10,2"
            VerticalAlignment="Center"
            Appearance="Secondary"
            Command="{Binding CommandeRechargerJeu}"
            Content="{Binding LibelleRechargerJeu}"
            IsEnabled="{Binding RechargerJeuActif}"
            ToolTip="{Binding ToolTipRechargerJeu}"
          />

          <ui:Button
            x:Name="BoutonCompteUtilisateur"
            Height="32"
            Padding="10,2"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Appearance="Secondary"
            Command="{Binding CommandeAfficherCompte}"
            Content="{Binding Compte.LibelleBouton}"
            ToolTip="Afficher le profil"
          />
        </StackPanel>
      </Grid>
    </Grid>

    <Border
      x:Name="CadreZonePrincipale"
      Grid.Row="2"
      Padding="{StaticResource PaddingFenetrePrincipale}"
      Background="Transparent"
    >
      <ScrollViewer
        x:Name="ZonePrincipale"
        Visibility="{Binding VisibiliteContenuPrincipal}"
        VerticalScrollBarVisibility="Hidden"
        HorizontalScrollBarVisibility="Disabled"
        SizeChanged="ZonePrincipale_TailleChangee"
        PreviewMouseWheel="ZonePrincipale_ApercuMoletteSouris"
        MouseMove="ZonePrincipale_DeplacementSouris"
        MouseLeave="ZonePrincipale_SortieSouris"
        ScrollChanged="ZonePrincipale_DefilementChange"
      >
        <Grid
          x:Name="ConteneurZonePrincipale"
          Margin="{StaticResource MargeFenetreContenu}"
          Background="Transparent"
          VerticalAlignment="Top"
        >
          <Grid x:Name="GrilleCartes" VerticalAlignment="Stretch">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="280" />
              <ColumnDefinition Width="{StaticResource EspaceColonnesPrincipal}" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid
              x:Name="CarteConnexion"
              Grid.Column="0"
              Visibility="{Binding VisibiliteCarteConnexion}"
            >
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="6" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <TextBlock
                Grid.Row="0"
                Margin="8,0,0,0"
                FontSize="24"
                FontWeight="SemiBold"
                Text="Connexion RetroAchievements"
              />

              <Border
                x:Name="CadreCarteConnexion"
                Grid.Row="2"
                Style="{StaticResource StyleSectionArrondie}"
              >
                <Grid>
                  <StackPanel x:Name="ContenuCarteConnexion">
                    <TextBlock
                      Opacity="0.78"
                      TextWrapping="Wrap"
                      Text="Renseigne ton pseudo et ta clé Web API pour charger ton dernier jeu joué, ta progression et tes succès récents."
                    />
                    <TextBlock
                      Margin="{StaticResource MargeBlocCompacte}"
                      Opacity="0.62"
                      TextWrapping="Wrap"
                      Text="Utilise le bouton Connexion en haut à droite pour commencer."
                    />
                  </StackPanel>
                </Grid>
              </Border>
            </Grid>

            <Grid
              x:Name="CarteJeuEnCours"
              Grid.Column="2"
              VerticalAlignment="Stretch"
              ClipToBounds="True"
              Visibility="{Binding VisibiliteCarteJeuEnCours}"
              SizeChanged="CadreSuccesJeuEnCours_TailleChangee"
            >
              <Grid.RowDefinitions>
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>

              <Border
                x:Name="CadreCarteJeuEnCours"
                Grid.Row="0"
                VerticalAlignment="Stretch"
                Style="{StaticResource StyleSectionArrondie}"
              >
                <Grid
                  x:Name="GrilleCarteJeuEnCours"
                  SizeChanged="CadreSuccesJeuEnCours_TailleChangee"
                >
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="0" />
                    <ColumnDefinition Width="0" />
                    <ColumnDefinition Width="0" />
                    <ColumnDefinition Width="0" />
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="0" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                  </Grid.RowDefinitions>

                  <Grid x:Name="EnTeteCarteJeuEnCours" Grid.Row="0" Grid.ColumnSpan="5">
                    <TextBlock
                      x:Name="TitreZoneJeuEnCours"
                      Margin="8,0,0,0"
                      FontSize="28"
                      FontWeight="SemiBold"
                      Text="{Binding TitreCarteJeuEnCours}"
                      Visibility="Collapsed"
                    />
                  </Grid>
                  <Grid x:Name="SectionResumeJeuEnCours" Grid.Row="2" VerticalAlignment="Stretch">
                    <Grid.RowDefinitions>
                      <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border
                      Grid.Row="0"
                      VerticalAlignment="Stretch"
                      Style="{StaticResource StyleSousCarteJeu}"
                    >
                      <Grid>
                        <Grid.RowDefinitions>
                          <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="{StaticResource EspaceColonnesPrincipal}" />
                            <ColumnDefinition Width="*" />
                          </Grid.ColumnDefinitions>

                          <Grid
                            x:Name="ColonneImageJeuEnCours"
                            Grid.Column="0"
                            VerticalAlignment="Stretch"
                          >
                            <Grid.RowDefinitions>
                              <RowDefinition Height="Auto" />
                              <RowDefinition Height="*" />
                              <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Border
                              Grid.Row="0"
                              x:Name="ConteneurImageJeuEnCours"
                              MaxWidth="180"
                              MaxHeight="252"
                              VerticalAlignment="Top"
                              HorizontalAlignment="Left"
                              CornerRadius="{StaticResource RayonCoinsPetit}"
                              BorderThickness="0"
                              Background="Transparent"
                            >
                              <Grid>
                                <Image
                                  x:Name="ImageJeuEnCours"
                                  Margin="0"
                                  MaxWidth="180"
                                  MaxHeight="252"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Top"
                                  Stretch="Uniform"
                                  SizeChanged="ImageJeuEnCours_TailleChangee"
                                  Visibility="Collapsed"
                                >
                                  <Image.RenderTransform>
                                    <TranslateTransform />
                                  </Image.RenderTransform>
                                </Image>
                                <Image
                                  x:Name="ImageJeuEnCoursTransition"
                                  Margin="0"
                                  MaxWidth="180"
                                  MaxHeight="252"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Top"
                                  Stretch="Uniform"
                                  SizeChanged="ImageJeuEnCours_TailleChangee"
                                  Visibility="Collapsed"
                                >
                                  <Image.RenderTransform>
                                    <TranslateTransform />
                                  </Image.RenderTransform>
                                </Image>
                                <TextBlock
                                  x:Name="TexteImageJeuEnCours"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Top"
                                  Margin="0"
                                  Opacity="0.62"
                                  Text="{Binding JeuCourant.TexteVisuelPrincipal}"
                                  TextAlignment="Center"
                                  TextWrapping="Wrap"
                                  Visibility="{Binding JeuCourant.TexteVisuelPrincipalVisible, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
                                />
                              </Grid>
                            </Border>
                            <ui:Button
                              x:Name="BoutonRejouerJeuEnCours"
                              Grid.Row="2"
                              Height="28"
                              Margin="{StaticResource MargeBlocCompacte}"
                              Padding="10,2"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Bottom"
                              Appearance="Secondary"
                              Command="{Binding JeuCourant.CommandeActionRejouer}"
                              Content="{Binding JeuCourant.LibelleActionRejouer}"
                              IsEnabled="{Binding JeuCourant.ActionRejouerActivee}"
                              ToolTip="{Binding JeuCourant.ToolTipActionRejouer}"
                              Visibility="{Binding JeuCourant.ActionRejouerVisible, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
                            />
                          </Grid>

                          <Grid Grid.Column="2" VerticalAlignment="Stretch">
                            <Grid.RowDefinitions>
                              <RowDefinition Height="Auto" />
                              <RowDefinition Height="Auto" />
                              <RowDefinition Height="*" />
                              <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" HorizontalAlignment="Stretch">
                              <Border
                                x:Name="ConteneurTitreJeuEnCours"
                                ClipToBounds="True"
                                VerticalAlignment="Top"
                                SizeChanged="TitreJeuEnCours_MiseEnPageChangee"
                              >
                                <Canvas
                                  x:Name="ZoneTitreJeuEnCours"
                                  Background="Transparent"
                                  Height="40"
                                  SizeChanged="TitreJeuEnCours_MiseEnPageChangee"
                                >
                                  <TextBlock
                                    x:Name="TexteTitreJeuEnCours"
                                    Margin="0"
                                    VerticalAlignment="Center"
                                    FontSize="24"
                                    FontWeight="SemiBold"
                                    Text="{Binding JeuCourant.Titre}"
                                    TextWrapping="NoWrap"
                                  >
                                    <TextBlock.RenderTransform>
                                      <TranslateTransform />
                                    </TextBlock.RenderTransform>
                                  </TextBlock>
                                </Canvas>
                              </Border>
                            </Grid>
                            <Grid
                              x:Name="GrilleInformationsJeuEnCours"
                              Grid.Row="1"
                              Margin="{StaticResource MargeBlocStandard}"
                              Visibility="{Binding JeuCourant.InformationsVisibles, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
                            >
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                              </Grid.ColumnDefinitions>
                              <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                              </Grid.RowDefinitions>

                              <TextBlock
                                x:Name="EtiquetteConsoleJeuEnCours"
                                Margin="0,0,12,6"
                                FontWeight="SemiBold"
                                Opacity="0.72"
                                Text="Console"
                                Visibility="{Binding JeuCourant.ConsoleVisible, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
                              />
                              <Grid
                                x:Name="ZoneConsoleJeuEnCours"
                                Grid.Column="1"
                                Margin="0,0,0,6"
                                Visibility="{Binding JeuCourant.ConsoleVisible, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
                              >
                                <Grid.ColumnDefinitions>
                                  <ColumnDefinition Width="Auto" />
                                  <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Image
                                  x:Name="ImageConsoleJeuEnCours"
                                  Grid.Column="0"
                                  Width="20"
                                  Height="20"
                                  Margin="0,0,8,0"
                                  VerticalAlignment="Center"
                                  Stretch="Uniform"
                                  Source="{Binding JeuCourant.ImageConsole}"
                                  Visibility="{Binding JeuCourant.ImageConsoleVisible, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
                                />
                                <TextBox
                                  x:Name="TexteConsoleJeuEnCours"
                                  Grid.Column="1"
                                  Style="{StaticResource StyleTexteCopiable}"
                                  VerticalAlignment="Center"
                                  FontSize="13"
                                  FontWeight="SemiBold"
                                  Opacity="0.86"
                                  Text="{Binding JeuCourant.Console, Mode=OneWay}"
                                  TextWrapping="Wrap"
                                  Visibility="{Binding JeuCourant.ConsoleVisible, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
                                />
                              </Grid>

                              <TextBlock
                                x:Name="EtiquetteTypeJeuEnCours"
                                Grid.Row="1"
                                Margin="0,0,12,6"
                                FontWeight="SemiBold"
                                Opacity="0.72"
                                Text="Genre"
                                Visibility="{Binding JeuCourant.GenreVisible, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
                              />
                              <TextBox
                                x:Name="TexteTypeJeuEnCours"
                                Grid.Row="1"
                                Grid.Column="1"
                                Margin="0,0,0,6"
                                Style="{StaticResource StyleTexteCopiable}"
                                Opacity="0.84"
                                Text="{Binding JeuCourant.Genre, Mode=OneWay}"
                                TextWrapping="Wrap"
                                Visibility="{Binding JeuCourant.GenreVisible, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
                              />

                              <TextBlock
                                x:Name="EtiquetteDateSortieJeuEnCours"
                                Grid.Row="2"
                                Margin="0,0,12,6"
                                FontWeight="SemiBold"
                                Opacity="0.72"
                                Text="Sortie"
                                Visibility="{Binding JeuCourant.DateSortieVisible, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
                              />
                              <TextBox
                                x:Name="TexteDateSortieJeuEnCours"
                                Grid.Row="2"
                                Grid.Column="1"
                                Margin="0,0,0,6"
                                Style="{StaticResource StyleTexteCopiable}"
                                Opacity="0.84"
                                Text="{Binding JeuCourant.DateSortie, Mode=OneWay}"
                                TextWrapping="Wrap"
                                Visibility="{Binding JeuCourant.DateSortieVisible, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
                              />

                              <TextBlock
                                x:Name="EtiquetteCreditsJeuEnCours"
                                Grid.Row="3"
                                Margin="0,0,12,6"
                                FontWeight="SemiBold"
                                Opacity="0.72"
                                Text="Crédits"
                                Visibility="{Binding JeuCourant.CreditsVisible, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
                              />
                              <TextBox
                                x:Name="TexteDeveloppeurJeuEnCours"
                                Grid.Row="3"
                                Grid.Column="1"
                                Margin="0,0,0,6"
                                Style="{StaticResource StyleTexteCopiable}"
                                Opacity="0.84"
                                Text="{Binding JeuCourant.Credits, Mode=OneWay}"
                                TextWrapping="Wrap"
                                Visibility="{Binding JeuCourant.CreditsVisible, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
                              />

                              <TextBlock
                                x:Name="EtiquetteTempsJeuEnCours"
                                Grid.Row="4"
                                Margin="0,0,12,6"
                                FontWeight="SemiBold"
                                Opacity="0.72"
                                Text="Temps de jeu"
                                Visibility="{Binding JeuCourant.TempsDeJeuVisible, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
                              />
                              <TextBox
                                x:Name="TexteTempsJeuEnCours"
                                Grid.Row="4"
                                Grid.Column="1"
                                Margin="0,0,0,6"
                                Style="{StaticResource StyleTexteCopiable}"
                                Opacity="0.84"
                                Text="{Binding JeuCourant.TempsDeJeu, Mode=OneWay}"
                                TextWrapping="Wrap"
                                Visibility="{Binding JeuCourant.TempsDeJeuVisible, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
                              />
                            </Grid>

                            <Grid
                              Grid.Row="3"
                              Margin="{StaticResource MargeBlocStandard}"
                              HorizontalAlignment="Stretch"
                            >
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                              </Grid.ColumnDefinitions>
                              <ui:Button
                                x:Name="BoutonVueDetailleeJeuEnCours"
                                Grid.Column="1"
                                Height="28"
                                Padding="10,2"
                                HorizontalAlignment="Right"
                                Appearance="Secondary"
                                Command="{Binding JeuCourant.CommandeActionDetails}"
                                Content="{Binding JeuCourant.LibelleActionDetails}"
                                IsEnabled="{Binding JeuCourant.ActionDetailsActivee}"
                                ToolTip="{Binding JeuCourant.ToolTipActionDetails}"
                                Visibility="{Binding JeuCourant.ActionDetailsVisible, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
                              />
                            </Grid>
                          </Grid>
                        </Grid>
                      </Grid>
                    </Border>
                  </Grid>

                  <Grid x:Name="SectionSuccesEnCours" Grid.Row="4" VerticalAlignment="Stretch">
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="6" />
                      <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                      <TextBlock
                        Margin="8,0,0,0"
                        FontWeight="SemiBold"
                        FontSize="18"
                        Text="Rétrosuccès en cours"
                      />
                    </Grid>

                    <Border
                      Grid.Row="2"
                      VerticalAlignment="Stretch"
                      Style="{StaticResource StyleSousCarteJeu}"
                    >
                      <Grid>
                        <Grid.RowDefinitions>
                          <RowDefinition Height="*" />
                          <RowDefinition Height="10" />
                          <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                          <Grid>
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="84" />
                              <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border
                              Grid.Column="0"
                              x:Name="CartePremierSuccesNonDebloqueVisuel"
                              VerticalAlignment="Top"
                              CornerRadius="{StaticResource RayonCoinsPetit}"
                              BorderThickness="0"
                              Background="Transparent"
                            >
                              <Grid>
                                <Image
                                  x:Name="ImagePremierSuccesNonDebloque"
                                  Source="{Binding SuccesEnCours.Image}"
                                  Margin="0"
                                  MaxWidth="84"
                                  MaxHeight="84"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Opacity="{Binding SuccesEnCours.ImageOpacity}"
                                  Stretch="Uniform"
                                  SizeChanged="ImagePremierSuccesNonDebloque_TailleChangee"
                                  Visibility="{Binding SuccesEnCours.ImageVisible, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
                                />
                                <TextBlock
                                  x:Name="TexteImagePremierSuccesNonDebloque"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Opacity="0.62"
                                  Text="{Binding SuccesEnCours.TexteVisuel}"
                                  TextAlignment="Center"
                                  TextWrapping="Wrap"
                                  Visibility="{Binding SuccesEnCours.TexteVisuelVisible, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
                                />
                              </Grid>
                            </Border>

                            <StackPanel Grid.Column="1" Margin="12,0,12,0">
                              <TextBox
                                x:Name="TexteTitrePremierSuccesNonDebloque"
                                Style="{StaticResource StyleTexteCopiable}"
                                FontSize="18"
                                FontWeight="SemiBold"
                                Text="{Binding SuccesEnCours.Titre}"
                                Visibility="{Binding SuccesEnCours.TitreVisible, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
                              />
                              <TextBox
                                x:Name="TexteDescriptionPremierSuccesNonDebloque"
                                Margin="0,4,0,0"
                                Style="{StaticResource StyleTexteCopiable}"
                                Opacity="0.78"
                                Text="{Binding SuccesEnCours.Description}"
                                TextWrapping="Wrap"
                                Visibility="{Binding SuccesEnCours.DescriptionVisible, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
                              />
                              <TextBox
                                x:Name="TextePointsPremierSuccesNonDebloque"
                                Margin="0,4,0,0"
                                Style="{StaticResource StyleTexteCopiable}"
                                Opacity="0.72"
                                Text="{Binding SuccesEnCours.DetailsPoints}"
                                TextWrapping="Wrap"
                                Visibility="{Binding SuccesEnCours.DetailsPointsVisible, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
                              />
                              <TextBox
                                x:Name="TexteFaisabilitePremierSuccesNonDebloque"
                                Margin="0,4,0,0"
                                Style="{StaticResource StyleTexteCopiable}"
                                Opacity="0.72"
                                Text="{Binding SuccesEnCours.DetailsFaisabilite}"
                                ToolTip="{Binding SuccesEnCours.ToolTipDetailsFaisabilite}"
                                TextWrapping="Wrap"
                                Visibility="{Binding SuccesEnCours.DetailsFaisabiliteVisible, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
                              />
                            </StackPanel>
                          </Grid>
                        </Grid>

                        <Grid Grid.Row="2" Margin="0" VerticalAlignment="Bottom">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>
                          <StackPanel
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            Orientation="Horizontal"
                          >
                            <ui:Button
                              x:Name="BoutonSuccesEnCoursPrecedent"
                              Width="30"
                              Height="26"
                              Margin="0,0,8,0"
                              Appearance="Secondary"
                              Command="{Binding SuccesEnCours.CommandePrecedent}"
                              IsEnabled="{Binding SuccesEnCours.PrecedentActif}"
                              ToolTip="Afficher le rétrosuccès précédent"
                              Visibility="{Binding SuccesEnCours.NavigationVisible, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
                            >
                              <TextBlock
                                x:Name="TexteChevronSuccesEnCoursPrecedent"
                                FontSize="20"
                                FontWeight="ExtraBold"
                                Opacity="{Binding SuccesEnCours.PrecedentOpacity}"
                                Text="‹"
                                TextAlignment="Center"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Margin="0,-5,0,-1"
                              />
                            </ui:Button>
                            <ui:Button
                              x:Name="BoutonSuccesEnCoursSuivant"
                              Width="30"
                              Height="26"
                              Appearance="Secondary"
                              Command="{Binding SuccesEnCours.CommandeSuivant}"
                              IsEnabled="{Binding SuccesEnCours.SuivantActif}"
                              ToolTip="Afficher le rétrosuccès suivant"
                              Visibility="{Binding SuccesEnCours.NavigationVisible, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
                            >
                              <TextBlock
                                x:Name="TexteChevronSuccesEnCoursSuivant"
                                FontSize="20"
                                FontWeight="ExtraBold"
                                Opacity="{Binding SuccesEnCours.SuivantOpacity}"
                                Text="›"
                                TextAlignment="Center"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Margin="0,-5,0,-1"
                              />
                            </ui:Button>
                          </StackPanel>
                          <ui:Button
                            x:Name="BoutonPasserSuccesEnCours"
                            Grid.Column="1"
                            Height="28"
                            Margin="8,0,0,0"
                            Padding="10,2"
                            Appearance="Secondary"
                            Command="{Binding SuccesEnCours.CommandePasser}"
                            Content="Passer"
                            IsEnabled="{Binding SuccesEnCours.PasserActif}"
                            ToolTip="Faire ce succès plus tard"
                            Visibility="{Binding SuccesEnCours.NavigationVisible, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
                          />
                        </Grid>
                      </Grid>
                    </Border>
                  </Grid>

                  <Grid
                    x:Name="SectionListeSuccesJeuEnCours"
                    Grid.Row="6"
                    VerticalAlignment="Stretch"
                  >
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="6" />
                      <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                      <TextBlock
                        Margin="8,0,0,0"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="Rétrosuccès du jeu"
                      />
                    </Grid>

                    <Border
                      x:Name="CarteListeSuccesJeuEnCours"
                      Grid.Row="2"
                      HorizontalAlignment="Stretch"
                      SizeChanged="CadreSuccesJeuEnCours_TailleChangee"
                      VerticalAlignment="Stretch"
                      Style="{StaticResource StyleSousCarteJeu}"
                    >
                      <Grid x:Name="StructureListeSuccesJeuEnCours">
                        <Grid.RowDefinitions>
                          <RowDefinition Height="*" />
                          <RowDefinition Height="10" />
                          <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid x:Name="ZonePrincipaleListeSuccesJeuEnCours" Grid.Row="0">
                          <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                          </Grid.RowDefinitions>
                          <Border Grid.Row="0" Style="{StaticResource StyleSousCarteJeu}">
                            <Grid>
                              <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                              </Grid.RowDefinitions>
                              <ProgressBar
                                x:Name="BarreProgressionJeuEnCours"
                                Grid.Row="0"
                                Height="8"
                                Margin="0"
                                Minimum="0"
                                Maximum="100"
                                Value="{Binding JeuCourant.ProgressionValeur, Mode=OneWay}"
                              />
                              <Grid Grid.Row="1" Margin="{StaticResource MargeBlocStandard}">
                                <Grid.ColumnDefinitions>
                                  <ColumnDefinition Width="Auto" />
                                  <ColumnDefinition Width="*" />
                                  <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                  x:Name="TextePourcentageJeuEnCours"
                                  Grid.Column="0"
                                  Margin="0,0,12,0"
                                  HorizontalAlignment="Left"
                                  MinHeight="22"
                                  Opacity="0.72"
                                  FontSize="13"
                                  LineHeight="18"
                                  LineStackingStrategy="BlockLineHeight"
                                  Text="{Binding JeuCourant.Pourcentage, Mode=OneWay}"
                                  TextAlignment="Left"
                                  TextWrapping="Wrap"
                                  VerticalAlignment="Center"
                                />
                                <TextBlock
                                  x:Name="TexteDetailsJeuEnCours"
                                  Grid.Column="1"
                                  Margin="0,0,12,0"
                                  HorizontalAlignment="Center"
                                  MinHeight="22"
                                  Opacity="0.72"
                                  FontSize="13"
                                  LineHeight="18"
                                  LineStackingStrategy="BlockLineHeight"
                                  TextWrapping="Wrap"
                                  Text="{Binding JeuCourant.Details, Mode=OneWay}"
                                  TextAlignment="Center"
                                  VerticalAlignment="Center"
                                  Visibility="{Binding JeuCourant.DetailsVisible, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
                                />
                                <TextBlock
                                  x:Name="TexteResumeProgressionJeuEnCours"
                                  Grid.Column="2"
                                  HorizontalAlignment="Right"
                                  MinHeight="22"
                                  Opacity="0.72"
                                  FontSize="13"
                                  LineHeight="18"
                                  LineStackingStrategy="BlockLineHeight"
                                  Text="{Binding JeuCourant.Progression, Mode=OneWay}"
                                  TextAlignment="Right"
                                  TextWrapping="Wrap"
                                  VerticalAlignment="Center"
                                />
                              </Grid>
                            </Grid>
                          </Border>

                          <Grid
                            x:Name="ZoneVisibleListeSuccesJeuEnCours"
                            Grid.Row="1"
                            Margin="{StaticResource MargeGrilleDense}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            ClipToBounds="True"
                            SizeChanged="ConteneurGrilleTousSuccesJeuEnCours_TailleChangee"
                          >
                            <ScrollViewer
                              x:Name="ConteneurGrilleTousSuccesJeuEnCours"
                              CanContentScroll="False"
                              HorizontalAlignment="Stretch"
                              HorizontalScrollBarVisibility="Disabled"
                              MouseEnter="ConteneurGrilleTousSuccesJeuEnCours_EntreeSouris"
                              MouseLeave="ConteneurGrilleTousSuccesJeuEnCours_SortieSouris"
                              ScrollChanged="ConteneurGrilleTousSuccesJeuEnCours_DefilementChange"
                              VerticalAlignment="Stretch"
                              VerticalScrollBarVisibility="Hidden"
                            >
                              <WrapPanel
                                x:Name="GrilleTousSuccesJeuEnCours"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                              />
                            </ScrollViewer>
                          </Grid>
                        </Grid>

                        <StackPanel
                          Grid.Row="2"
                          Margin="0"
                          HorizontalAlignment="Right"
                          Orientation="Horizontal"
                          VerticalAlignment="Bottom"
                        >
                          <ui:Button
                            x:Name="BoutonOrdreSuccesGrille"
                            Height="28"
                            Padding="10,2"
                            Appearance="Secondary"
                            Click="BoutonOrdreSuccesGrille_Click"
                            Content="{Binding LibelleOrdreSuccesGrille}"
                            ToolTip="Changer le mode d'affichage des rétrosuccès"
                          >
                            <ui:Button.ContextMenu>
                              <ContextMenu
                                x:Name="MenuOrdreSuccesGrille"
                                DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                              >
                                <MenuItem
                                  x:Name="MenuItemOrdreSuccesNormal"
                                  Command="{Binding CommandeOrdreSuccesNormal}"
                                >
                                  <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                      <Grid Width="12" Height="12" Margin="0,0,6,0">
                                        <Ellipse
                                          x:Name="ContourOrdreSuccesNormal"
                                          Stroke="{Binding ContourOrdreSuccesNormal}"
                                          StrokeThickness="1.2"
                                        />
                                        <Ellipse
                                          x:Name="CentreOrdreSuccesNormal"
                                          Width="6"
                                          Height="6"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Visibility="{Binding OrdreSuccesNormalActif, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
                                        />
                                      </Grid>
                                      <TextBlock VerticalAlignment="Center" Text="Normal" />
                                    </StackPanel>
                                  </MenuItem.Header>
                                </MenuItem>
                                <MenuItem
                                  x:Name="MenuItemOrdreSuccesFacile"
                                  Command="{Binding CommandeOrdreSuccesFacile}"
                                >
                                  <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                      <Grid Width="12" Height="12" Margin="0,0,6,0">
                                        <Ellipse
                                          x:Name="ContourOrdreSuccesFacile"
                                          Stroke="{Binding ContourOrdreSuccesFacile}"
                                          StrokeThickness="1.2"
                                        />
                                        <Ellipse
                                          x:Name="CentreOrdreSuccesFacile"
                                          Width="6"
                                          Height="6"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Visibility="{Binding OrdreSuccesFacileActif, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
                                        />
                                      </Grid>
                                      <TextBlock VerticalAlignment="Center" Text="Facile" />
                                    </StackPanel>
                                  </MenuItem.Header>
                                </MenuItem>
                                <MenuItem
                                  x:Name="MenuItemOrdreSuccesDifficile"
                                  Command="{Binding CommandeOrdreSuccesDifficile}"
                                >
                                  <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                      <Grid Width="12" Height="12" Margin="0,0,6,0">
                                        <Ellipse
                                          x:Name="ContourOrdreSuccesDifficile"
                                          Stroke="{Binding ContourOrdreSuccesDifficile}"
                                          StrokeThickness="1.2"
                                        />
                                        <Ellipse
                                          x:Name="CentreOrdreSuccesDifficile"
                                          Width="6"
                                          Height="6"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Visibility="{Binding OrdreSuccesDifficileActif, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
                                        />
                                      </Grid>
                                      <TextBlock VerticalAlignment="Center" Text="Difficile" />
                                    </StackPanel>
                                  </MenuItem.Header>
                                </MenuItem>
                                <MenuItem
                                  x:Name="MenuItemOrdreSuccesAleatoire"
                                  Command="{Binding CommandeOrdreSuccesAleatoire}"
                                >
                                  <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                      <Grid Width="12" Height="12" Margin="0,0,6,0">
                                        <Ellipse
                                          x:Name="ContourOrdreSuccesAleatoire"
                                          Stroke="{Binding ContourOrdreSuccesAleatoire}"
                                          StrokeThickness="1.2"
                                        />
                                        <Ellipse
                                          x:Name="CentreOrdreSuccesAleatoire"
                                          Width="6"
                                          Height="6"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Visibility="{Binding OrdreSuccesAleatoireActif, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
                                        />
                                      </Grid>
                                      <TextBlock VerticalAlignment="Center" Text="Aléatoire" />
                                    </StackPanel>
                                  </MenuItem.Header>
                                </MenuItem>
                              </ContextMenu>
                            </ui:Button.ContextMenu>
                          </ui:Button>
                        </StackPanel>

                        <Grid Grid.Row="2" Visibility="Collapsed">
                          <TextBlock
                            x:Name="TexteEtatSuccesRecents"
                            Text="Les succès récents apparaîtront ici."
                          />
                          <TextBlock
                            x:Name="TexteSuccesRecent1"
                            Text="Aucun succès récent à afficher."
                          />
                          <TextBlock
                            x:Name="TexteSuccesRecent2"
                            Text="Aucun succès récent à afficher."
                          />
                          <TextBlock
                            x:Name="TexteSuccesRecent3"
                            Text="Aucun succès récent à afficher."
                          />
                        </Grid>
                      </Grid>
                    </Border>
                  </Grid>
                </Grid>
              </Border>
            </Grid>
          </Grid>
        </Grid>
      </ScrollViewer>
    </Border>

    <Grid
      x:Name="VoileFenetreConnexion"
      Grid.RowSpan="4"
      Panel.ZIndex="10"
      Visibility="Collapsed"
      Background="#88000000"
      IsHitTestVisible="False"
    />

    <Grid
      x:Name="OverlayConnexion"
      Grid.RowSpan="4"
      Panel.ZIndex="20"
      Visibility="Collapsed"
      Background="#88000000"
      IsHitTestVisible="True"
      Focusable="True"
    >
      <Border
        Width="430"
        MaxWidth="430"
        Padding="16"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Background="{DynamicResource ControlFillColorDefaultBrush}"
        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="12"
        KeyboardNavigation.TabNavigation="Cycle"
      >
        <StackPanel>
          <TextBlock
            FontSize="20"
            FontWeight="SemiBold"
            Text="Connexion RetroAchievements"
            Margin="0,0,0,8"
          />
          <TextBlock
            Opacity="0.84"
            TextWrapping="Wrap"
            Margin="0,0,0,14"
            Text="Entre ton pseudo et ta clé Web API pour synchroniser ton dernier jeu joué, ta progression et tes succès récents."
          />

          <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="Pseudo" />
          <TextBox x:Name="ChampPseudoConnexion" MinWidth="360" Padding="10,6" Margin="0,0,0,14" />

          <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="Clé API" />
          <PasswordBox x:Name="ChampCleApiConnexion" MinWidth="360" Padding="10,6" />

          <TextBlock
            Margin="0,10,0,0"
            Opacity="0.68"
            TextWrapping="Wrap"
            Text="Tu peux retrouver cette clé depuis ton compte RetroAchievements, dans la section dédiée à l'API Web."
          />

          <TextBlock
            x:Name="TexteErreurConnexion"
            Margin="0,12,0,0"
            Foreground="IndianRed"
            TextWrapping="Wrap"
            Visibility="Collapsed"
          />

          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,0">
            <Button
              x:Name="BoutonEnregistrerConnexion"
              MinWidth="120"
              Padding="14,6"
              Margin="0,0,8,0"
              IsDefault="True"
              Content="Enregistrer"
            />
            <Button
              x:Name="BoutonAnnulerConnexion"
              MinWidth="120"
              Padding="14,6"
              IsCancel="True"
              Content="Fermer"
            />
          </StackPanel>
        </StackPanel>
      </Border>
    </Grid>

    <Border
      x:Name="BarreEtatApplication"
      Grid.Row="3"
      Margin="12,0,12,10"
      Padding="0,3,0,0"
      Background="Transparent"
    >
      <Grid VerticalAlignment="Center">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <ui:Button
          x:Name="BoutonAide"
          Grid.Column="0"
          Width="24"
          Height="24"
          Margin="0,0,10,0"
          Padding="0"
          HorizontalAlignment="Left"
          VerticalAlignment="Center"
          Appearance="Secondary"
          Command="{Binding CommandeAfficherAide}"
          Content="?"
          ToolTip="Afficher l'aide"
        >
          <ui:Button.Style>
            <Style TargetType="ui:Button">
              <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
              <Setter
                Property="Background"
                Value="{DynamicResource ControlFillColorSecondaryBrush}"
              />
              <Setter
                Property="BorderBrush"
                Value="{DynamicResource ControlStrokeColorDefaultBrush}"
              />
              <Setter Property="BorderThickness" Value="1" />
              <Setter Property="Cursor" Value="Hand" />
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="ui:Button">
                    <Border
                      Width="{TemplateBinding Width}"
                      Height="{TemplateBinding Height}"
                      Background="{TemplateBinding Background}"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}"
                      CornerRadius="12"
                    >
                      <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Setter
                          Property="Background"
                          Value="{DynamicResource ControlFillColorTertiaryBrush}"
                        />
                      </Trigger>
                      <Trigger Property="IsPressed" Value="True">
                        <Setter
                          Property="Background"
                          Value="{DynamicResource ControlFillColorInputActiveBrush}"
                        />
                      </Trigger>
                      <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Opacity" Value="0.6" />
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </ui:Button.Style>
        </ui:Button>

        <TextBlock
          Grid.Column="1"
          Margin="0"
          MinWidth="96"
          HorizontalAlignment="Left"
          VerticalAlignment="Center"
          FontSize="12"
          Opacity="0.62"
          Text="{Binding EtatSynchronisationJeu}"
          Visibility="{Binding VisibiliteSynchronisationJeu}"
        />

        <StackPanel
          Grid.Column="2"
          HorizontalAlignment="Right"
          Orientation="Horizontal"
          VerticalAlignment="Center"
        >
          <Button
            x:Name="BoutonMiseAJourApplication"
            Margin="0,0,10,0"
            MinHeight="24"
            Padding="10,2,10,2"
            Command="{Binding CommandeMiseAJourApplication}"
            Content="{Binding LibelleMiseAJourApplication}"
            IsEnabled="{Binding MiseAJourApplicationActivee}"
            ToolTip="{Binding ToolTipMiseAJourApplication}"
            VerticalAlignment="Center"
            Visibility="{Binding VisibiliteMiseAJourApplication}"
          >
            <Button.Style>
              <Style TargetType="Button">
                <Setter Property="Foreground" Value="White" />
                <Setter Property="Background" Value="#15512C" />
                <Setter Property="BorderBrush" Value="#15512C" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                  <Setter.Value>
                    <ControlTemplate TargetType="Button">
                      <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="6"
                      >
                        <ContentPresenter
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Margin="{TemplateBinding Padding}"
                        />
                      </Border>
                      <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                          <Setter Property="Background" Value="#2A6B41" />
                          <Setter Property="BorderBrush" Value="#2A6B41" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                          <Setter Property="Background" Value="#114524" />
                          <Setter Property="BorderBrush" Value="#114524" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                          <Setter Property="Opacity" Value="0.55" />
                        </Trigger>
                      </ControlTemplate.Triggers>
                    </ControlTemplate>
                  </Setter.Value>
                </Setter>
              </Style>
            </Button.Style>
          </Button>
          <TextBlock
            x:Name="TexteVersionApplication"
            Margin="0,0,10,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            FontSize="12"
            FontWeight="SemiBold"
            Opacity="0.68"
            Text="Version"
            TextAlignment="Right"
          />

          <Button
            x:Name="BoutonDepotGitHub"
            Width="24"
            Height="24"
            Padding="0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            ToolTip="Projet GitHub RA-Compagnon"
            Background="Transparent"
            BorderThickness="0"
            Cursor="Hand"
            Click="BoutonDepotGitHub_Click"
          >
            <Button.Style>
              <Style TargetType="Button">
                <Setter Property="Template">
                  <Setter.Value>
                    <ControlTemplate TargetType="Button">
                      <Border
                        Width="{TemplateBinding Width}"
                        Height="{TemplateBinding Height}"
                        Background="Transparent"
                      >
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                      </Border>
                    </ControlTemplate>
                  </Setter.Value>
                </Setter>
                <Setter Property="Focusable" Value="False" />
                <Setter Property="Opacity" Value="0.74" />
                <Style.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1" />
                  </Trigger>
                  <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.86" />
                  </Trigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
            <Viewbox Stretch="Uniform">
              <Path
                Fill="#E6E6E6"
                Opacity="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Opacity}"
                Data="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38
                    0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13
                    -.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66
                    .07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15
                    -.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82A7.56 7.56 0 0 1 8 4.69c.68 0 1.36.09
                    2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15
                    0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2
                    0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
              />
            </Viewbox>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <ui:ContentDialogHost
      x:Name="RacineModales"
      Grid.RowSpan="4"
      Background="Transparent"
      IsHitTestVisible="False"
      Visibility="Collapsed"
      Panel.ZIndex="11"
    />
  </Grid>
</ui:FluentWindow>
