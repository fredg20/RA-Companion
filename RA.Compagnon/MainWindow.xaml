                                            />
                                            <Ellipse
                                              x:Name="CentreOrdreSuccesFacile"
                                              Width="6"
                                              Height="6"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Visibility="{Binding OrdreSuccesFacileActif, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
                                            />
                                          </Grid>
                                          <TextBlock VerticalAlignment="Center" Text="Facile" />
                                        </StackPanel>
                                      </MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem
                                      x:Name="MenuItemOrdreSuccesDifficile"
                                      Command="{Binding CommandeOrdreSuccesDifficile}"
                                    >
                                      <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                          <Grid Width="12" Height="12" Margin="0,0,6,0">
                                            <Ellipse
                                              x:Name="ContourOrdreSuccesDifficile"
                                              Stroke="{Binding ContourOrdreSuccesDifficile}"
                                              StrokeThickness="1.2"
                                            />
                                            <Ellipse
                                              x:Name="CentreOrdreSuccesDifficile"
                                              Width="6"
                                              Height="6"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Visibility="{Binding OrdreSuccesDifficileActif, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
                                            />
                                          </Grid>
                                          <TextBlock VerticalAlignment="Center" Text="Difficile" />
                                        </StackPanel>
                                      </MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem
                                      x:Name="MenuItemOrdreSuccesAleatoire"
                                      Command="{Binding CommandeOrdreSuccesAleatoire}"
                                    >
                                      <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                          <Grid Width="12" Height="12" Margin="0,0,6,0">
                                            <Ellipse
                                              x:Name="ContourOrdreSuccesAleatoire"
                                              Stroke="{Binding ContourOrdreSuccesAleatoire}"
                                              StrokeThickness="1.2"
                                            />
                                            <Ellipse
                                              x:Name="CentreOrdreSuccesAleatoire"
                                              Width="6"
                                              Height="6"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Visibility="{Binding OrdreSuccesAleatoireActif, Converter={StaticResource ConvertisseurBooleenVersVisibilite}}"
                                            />
                                          </Grid>
                                          <TextBlock VerticalAlignment="Center" Text="Aléatoire" />
                                        </StackPanel>
                                      </MenuItem.Header>
                                    </MenuItem>
                                  </ContextMenu>
                                </ui:Button.ContextMenu>
                              </ui:Button>
                            </StackPanel>
                          </Grid>

                          <Grid Grid.Row="2" Visibility="Collapsed">
                            <TextBlock
                              x:Name="TexteEtatSuccesRecents"
                              Text="Les succès récents apparaîtront ici."
                            />
                            <TextBlock
                              x:Name="TexteSuccesRecent1"
                              Text="Aucun succès récent à afficher."
                            />
                            <TextBlock
                              x:Name="TexteSuccesRecent2"
                              Text="Aucun succès récent à afficher."
                            />
                            <TextBlock
                              x:Name="TexteSuccesRecent3"
                              Text="Aucun succès récent à afficher."
                            />
                          </Grid>
                        </Grid>
                      </Border>
                    </Grid>
                  </Grid>
                </Border>
              </Grid>
            </Grid>
          </Grid>
        </ScrollViewer>
      </Border>
      <modules:BibliothequeModuleView Visibility="{Binding VisibiliteModuleBibliotheque}" />
    </Grid>

    <Grid
      x:Name="VoileFenetreConnexion"
      Grid.RowSpan="5"
      Panel.ZIndex="10"
      Visibility="Collapsed"
      Background="#88000000"
      IsHitTestVisible="False"
    />

    <Grid
      x:Name="OverlayConnexion"
      Grid.RowSpan="5"
      Panel.ZIndex="20"
      Visibility="Collapsed"
      Background="#88000000"
      IsHitTestVisible="True"
      Focusable="True"
    >
      <Border
        Width="{x:Static compagnon:ConstantesDesign.LargeurCarteConnexion}"
        MaxWidth="{x:Static compagnon:ConstantesDesign.LargeurCarteConnexion}"
        Padding="{x:Static compagnon:ConstantesDesign.PaddingCarteSecondaire}"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Background="{DynamicResource ControlFillColorDefaultBrush}"
        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
        BorderThickness="{x:Static compagnon:ConstantesDesign.EpaisseurContourFin}"
        CornerRadius="{x:Static compagnon:ConstantesDesign.RayonCoinsStandard}"
        KeyboardNavigation.TabNavigation="Cycle"
      >
        <StackPanel>
          <TextBlock
            FontSize="{x:Static compagnon:ConstantesDesign.TaillePoliceTitreSection}"
            FontWeight="SemiBold"
            Text="Connexion RetroAchievements"
            Margin="0,0,0,8"
          />
          <TextBlock
            Opacity="0.84"
            TextWrapping="Wrap"
            Margin="0,0,0,14"
            Text="Entre ton pseudo et ta clé Web API pour synchroniser ton dernier jeu joué, ta progression et tes succès récents."
          />

          <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="Pseudo" />
          <TextBox
            x:Name="ChampPseudoConnexion"
            MinWidth="{x:Static compagnon:ConstantesDesign.LargeurContenuModaleConnexion}"
            Padding="{x:Static compagnon:ConstantesDesign.PaddingChampSaisie}"
            Margin="0,0,0,14"
          />

          <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="Clé API" />
          <PasswordBox
            x:Name="ChampCleApiConnexion"
            MinWidth="{x:Static compagnon:ConstantesDesign.LargeurContenuModaleConnexion}"
            Padding="{x:Static compagnon:ConstantesDesign.PaddingChampSaisie}"
          />

          <TextBlock
            Margin="0,10,0,0"
            Opacity="0.68"
            TextWrapping="Wrap"
            Text="Tu peux retrouver cette clé depuis ton compte RetroAchievements, dans la section dédiée à l'API Web."
          />

          <TextBlock
            x:Name="TexteErreurConnexion"
            Margin="0,12,0,0"
            Foreground="IndianRed"
            TextWrapping="Wrap"
            Visibility="Collapsed"
          />

          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,0">
            <Button
              x:Name="BoutonEnregistrerConnexion"
              MinWidth="{x:Static compagnon:ConstantesDesign.LargeurBoutonPrincipal}"
              Height="{x:Static compagnon:ConstantesDesign.HauteurBoutonPrincipal}"
              Padding="{x:Static compagnon:ConstantesDesign.PaddingBoutonPrincipal}"
              Margin="{x:Static compagnon:ConstantesDesign.MargeActionAdjacente}"
              IsDefault="True"
              Content="Enregistrer"
            />
            <Button
              x:Name="BoutonAnnulerConnexion"
              MinWidth="{x:Static compagnon:ConstantesDesign.LargeurBoutonPrincipal}"
              Height="{x:Static compagnon:ConstantesDesign.HauteurBoutonPrincipal}"
              Padding="{x:Static compagnon:ConstantesDesign.PaddingBoutonPrincipal}"
              IsCancel="True"
              Content="Fermer"
            />
          </StackPanel>
        </StackPanel>
      </Border>
    </Grid>

    <Border
      x:Name="BarreEtatApplication"
      Grid.Row="4"
      Margin="12,0,12,10"
      Padding="0,3,0,0"
      Background="Transparent"
    >
      <Grid VerticalAlignment="Center">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel
          Grid.Column="0"
          HorizontalAlignment="Left"
          Orientation="Horizontal"
          VerticalAlignment="Center"
        >
          <ui:Button
            x:Name="BoutonAide"
            Width="{x:Static compagnon:ConstantesDesign.TailleBoutonIcone}"
            Height="{x:Static compagnon:ConstantesDesign.TailleBoutonIcone}"
            Margin="{x:Static compagnon:ConstantesDesign.MargeActionAdjacente}"
            Padding="0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Appearance="Secondary"
            Command="{Binding CommandeAfficherAide}"
            Content="?"
            ToolTip="Afficher l'aide"
            Style="{StaticResource StyleBoutonIconeSecondaire}"
          />

          <ui:Button
            x:Name="BoutonRechargerJeu"
            Width="{x:Static compagnon:ConstantesDesign.TailleBoutonIcone}"
            Height="{x:Static compagnon:ConstantesDesign.TailleBoutonIcone}"
            Margin="{x:Static compagnon:ConstantesDesign.MargeActionAdjacente}"
            Padding="0"
            VerticalAlignment="Center"
            Appearance="Secondary"
            Command="{Binding CommandeRechargerJeu}"
            IsEnabled="{Binding RechargerJeuActif}"
            ToolTip="{Binding ToolTipRechargerJeu}"
            Style="{StaticResource StyleBoutonIconeSecondaire}"
          >
            <Viewbox Width="14" Height="14" Stretch="Uniform">
              <TextBlock
                FontSize="{x:Static compagnon:ConstantesDesign.TailleIconeStandard}"
                LineHeight="16"
                LineStackingStrategy="BlockLineHeight"
                Margin="0,-1,0,1"
                Text="↻"
                TextAlignment="Center"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                RenderTransformOrigin="0.5,0.5"
              >
                <TextBlock.RenderTransform>
                  <RotateTransform Angle="45" />
                </TextBlock.RenderTransform>
              </TextBlock>
            </Viewbox>
          </ui:Button>
        </StackPanel>

        <TextBlock
          Grid.Column="1"
          Margin="0"
          MinWidth="96"
          HorizontalAlignment="Left"
          VerticalAlignment="Center"
          FontSize="{x:Static compagnon:ConstantesDesign.TaillePoliceSecondaire}"
          Opacity="{x:Static compagnon:ConstantesDesign.OpaciteSecondaire}"
          Text="{Binding EtatSynchronisationJeu}"
          Visibility="{Binding VisibiliteSynchronisationJeu}"
        />

        <StackPanel
          Grid.Column="2"
          HorizontalAlignment="Right"
          Orientation="Horizontal"
          VerticalAlignment="Center"
        >
          <Button
            x:Name="BoutonMiseAJourApplication"
            Margin="{x:Static compagnon:ConstantesDesign.MargeActionAdjacente}"
            Height="{x:Static compagnon:ConstantesDesign.HauteurBoutonAction}"
            Padding="{x:Static compagnon:ConstantesDesign.PaddingBoutonActionCompact}"
            Command="{Binding CommandeMiseAJourApplication}"
            Content="{Binding LibelleMiseAJourApplication}"
            IsEnabled="{Binding MiseAJourApplicationActivee}"
            ToolTip="{Binding ToolTipMiseAJourApplication}"
            VerticalAlignment="Center"
            Visibility="{Binding VisibiliteMiseAJourApplication}"
          >
            <Button.Style>
              <Style TargetType="Button">
                <Setter Property="Foreground" Value="White" />
                <Setter Property="Background" Value="#15512C" />
                <Setter Property="BorderBrush" Value="#15512C" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                  <Setter.Value>
                    <ControlTemplate TargetType="Button">
                      <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{x:Static compagnon:ConstantesDesign.RayonBoutonAction}"
                      >
                        <ContentPresenter
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Margin="{TemplateBinding Padding}"
                        />
                      </Border>
                      <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                          <Setter Property="Background" Value="#2A6B41" />
                          <Setter Property="BorderBrush" Value="#2A6B41" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                          <Setter Property="Background" Value="#114524" />
                          <Setter Property="BorderBrush" Value="#114524" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                          <Setter Property="Opacity" Value="0.55" />
                        </Trigger>
                      </ControlTemplate.Triggers>
                    </ControlTemplate>
                  </Setter.Value>
                </Setter>
              </Style>
            </Button.Style>
          </Button>
          <TextBlock
            x:Name="TexteVersionApplication"
            Margin="{x:Static compagnon:ConstantesDesign.MargeActionAdjacente}"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            FontSize="{x:Static compagnon:ConstantesDesign.TaillePoliceSecondaire}"
            FontWeight="SemiBold"
            Opacity="0.68"
            Text="Version"
            TextAlignment="Right"
          />

          <Button
            x:Name="BoutonDepotGitHub"
            Width="{x:Static compagnon:ConstantesDesign.TailleBoutonIcone}"
            Height="{x:Static compagnon:ConstantesDesign.TailleBoutonIcone}"
            Padding="0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            ToolTip="Projet GitHub RA-Compagnon"
            Background="Transparent"
            BorderThickness="0"
            Cursor="Hand"
            Click="BoutonDepotGitHub_Click"
          >
            <Button.Style>
              <Style TargetType="Button">
                <Setter Property="Template">
                  <Setter.Value>
                    <ControlTemplate TargetType="Button">
                      <Border
                        Width="{TemplateBinding Width}"
                        Height="{TemplateBinding Height}"
                        Background="Transparent"
                      >
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                      </Border>
                    </ControlTemplate>
                  </Setter.Value>
                </Setter>
                <Setter Property="Focusable" Value="False" />
                <Setter Property="Opacity" Value="0.74" />
                <Style.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1" />
                  </Trigger>
                  <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.86" />
                  </Trigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
            <Viewbox Stretch="Uniform">
              <Path
                Fill="#E6E6E6"
                Opacity="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Opacity}"
                Data="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38
                    0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13
                    -.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66
                    .07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15
                    -.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82A7.56 7.56 0 0 1 8 4.69c.68 0 1.36.09
                    2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15
                    0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2
                    0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
              />
            </Viewbox>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <ui:ContentDialogHost
      x:Name="RacineModales"
      Grid.RowSpan="5"
      Background="Transparent"
      IsHitTestVisible="False"
      Visibility="Collapsed"
      Panel.ZIndex="11"
    />
  </Grid>
</ui:FluentWindow>

