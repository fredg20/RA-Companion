<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>..\rac.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="WPF-UI" Version="4.2.0" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="..\rac.ico" Link="rac.ico" />
  </ItemGroup>

  <ItemGroup Condition="Exists('..\native\ra_compagnon_rcheevos_bridge\build-zig\ra_compagnon_rcheevos_bridge.dll')">
    <Content
      Include="..\native\ra_compagnon_rcheevos_bridge\build-zig\ra_compagnon_rcheevos_bridge.dll"
      Link="ra_compagnon_rcheevos_bridge.dll"
    >
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
</Project>
